{
  "name": "arlo-sdk",
  "version": "0.1.2",
  "description": "Core TypeScript client and CLI for connecting apps to Arlo flows.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "arlo-sdk": "./bin/arlo-sdk.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build"
  },
  "sideEffects": false,
  "dependencies": {
    "zod": "^4.3.6"
  }
}
