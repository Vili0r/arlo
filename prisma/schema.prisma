// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

// Define database connection via the `DATABASE_URL` env var
datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(cuid())
  name      String
  platform  Platform @default(REACT_NATIVE)
  iconUrl   String?
  userId    String // from Clerk auth, e.g. "user_2x7..."
  apiKeys   ApiKey[]
  flows     Flow[]
  entryPoints EntryPoint[]
  registryKeys CustomRegistryKey[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("projects")
}

enum Platform {
  REACT_NATIVE
  EXPO
}

model ApiKey {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String // e.g. "Production", "Development"
  hashedKey   String      @unique
  prefix      String // visible prefix e.g. "ob_live_abc1" or "ob_test_xyz9"
  environment Environment
  lastUsedAt  DateTime?
  createdAt   DateTime    @default(now())

  @@index([projectId])
  @@index([hashedKey])
  @@map("api_keys")
}

enum Environment {
  DEVELOPMENT
  PRODUCTION
}

model Flow {
  id                   String        @id @default(cuid())
  projectId            String
  project              Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                 String // display name in dashboard
  slug                 String // SDK identifier, e.g. "welcome", "upgrade-prompt"
  status               FlowStatus    @default(DRAFT)
  draftConfig          Json?
  draftUpdatedAt       DateTime?
  developmentVersionId String?       @unique
  developmentVersion   FlowVersion?  @relation("DevelopmentPublishedVersion", fields: [developmentVersionId], references: [id])
  productionVersionId  String?       @unique
  productionVersion    FlowVersion?  @relation("ProductionPublishedVersion", fields: [productionVersionId], references: [id])
  versions             FlowVersion[] @relation("FlowVersions")
  entryPoints          EntryPoint[]  @relation("EntryPointPrimaryFlow")
  entryPointsAsVariant EntryPoint[]  @relation("EntryPointVariantFlow")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("flows")
}

enum FlowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model FlowVersion {
  id                        String       @id @default(cuid())
  flowId                    String
  flow                      Flow         @relation("FlowVersions", fields: [flowId], references: [id], onDelete: Cascade)
  version                   Int // auto-incremented per flow: v1, v2, v3...
  config                    Json // full screen/component tree (see structure above)
  changelog                 String? // optional note: "Added new welcome screen"
  developmentPublishedFlow  Flow?        @relation("DevelopmentPublishedVersion")
  productionPublishedFlow   Flow?        @relation("ProductionPublishedVersion")
  publishedEnvironment      Environment?
  publishedAt               DateTime?
  createdAt                 DateTime     @default(now())

  @@unique([flowId, version])
  @@index([flowId])
  @@map("flow_versions")
}

model EntryPoint {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  flowId      String
  flow        Flow        @relation("EntryPointPrimaryFlow", fields: [flowId], references: [id], onDelete: Cascade)
  variantFlowId String?
  variantFlow  Flow?      @relation("EntryPointVariantFlow", fields: [variantFlowId], references: [id], onDelete: SetNull)
  variantPercentage Int?
  key         String
  name        String?
  environment Environment @default(DEVELOPMENT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([projectId, key, environment])
  @@index([projectId])
  @@index([flowId])
  @@index([variantFlowId])
  @@map("entry_points")
}

model CustomRegistryKey {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key         String
  type        RegistryKeyType
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([projectId, key, type])
  @@index([projectId])
  @@map("custom_registry_keys")
}

enum RegistryKeyType {
  SCREEN
  COMPONENT
}

model FigmaConnection {
  id                    String   @id @default(cuid())
  userId                String   @unique
  figmaUserId           String?
  figmaHandle           String?
  figmaEmail            String?
  figmaAvatarUrl        String?
  accessTokenCiphertext String
  refreshTokenCiphertext String
  tokenType             String   @default("bearer")
  expiresAt             DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@map("figma_connections")
}
